meta {
  name: Atualizar descrição do grupo
  type: http
  seq: 10
}

put {
  url: {{baseUrl}}/api/groups/:groupId/description
  body: json
  auth: inherit
}

params:path {
  groupId: 
}

headers {
  X-Session-Id: {{sessionId}}
  Content-Type: application/json
}

body:json {
  {
    "description": "Descrição atualizada do grupo."
  }
}

settings {
  encodeUrl: true
}
