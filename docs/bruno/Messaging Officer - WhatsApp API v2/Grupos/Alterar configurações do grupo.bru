meta {
  name: Alterar configurações do grupo
  type: http
  seq: 11
}

put {
  url: {{baseUrl}}/api/groups/:groupId/settings
  body: json
  auth: inherit
}

params:path {
  groupId: 
}

headers {
  X-Session-Id: {{sessionId}}
  Content-Type: application/json
}

body:json {
  {
    "setting": "announcement"
  }
}

settings {
  encodeUrl: true
}
