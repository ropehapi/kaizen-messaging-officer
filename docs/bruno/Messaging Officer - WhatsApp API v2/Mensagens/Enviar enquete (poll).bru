meta {
  name: Enviar enquete (poll)
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/api/send-poll
  body: json
  auth: inherit
}

headers {
  X-Session-Id: {{sessionId}}
  Content-Type: application/json
}

body:json {
  {
    "number": "5511999999999",
    "name": "Qual sua linguagem favorita?",
    "options": [
      "JavaScript",
      "Python",
      "Go",
      "Rust"
    ],
    "selectableCount": 1
  }
}

settings {
  encodeUrl: true
}
