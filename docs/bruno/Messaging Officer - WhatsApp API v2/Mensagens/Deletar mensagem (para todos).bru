meta {
  name: Deletar mensagem (para todos)
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/api/delete-message
  body: json
  auth: inherit
}

headers {
  X-Session-Id: {{sessionId}}
  Content-Type: application/json
}

body:json {
  {
    "number": "5511999999999",
    "messageId": "ABCDEF1234567890",
    "fromMe": true
  }
}

settings {
  encodeUrl: true
}
